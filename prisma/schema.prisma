generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id              String           @id @default(cuid())
  name            String
  company         String?
  position        String?
  sessionId       String?
  cvText          String?
  jobDescription  String?
  gapAnalysis     String?
  coachingState   Json?
  overallScore    Float?           @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  chats           Chat[]
  documents       Document[]
  vectorDocuments VectorDocument[]

  @@index([sessionId])
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  label     String?
  text      String
  createdAt DateTime @default(now())
}

model Chat {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String    @default("preparation")
  persona   String    @default("structured")
  status    String    @default("active")
  metadata  Json?
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([projectId])
}

model Message {
  id           String   @id @default(cuid())
  chatId       String
  chat         Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role         String
  content      String
  score        Float?
  category     String?
  flagged      Boolean  @default(false)
  cost         Float?
  tokens       Int?
  inputTokens  Int?
  model        String?
  versionGroup String?
  active       Boolean  @default(true)
  toolCalls    Json?
  createdAt    DateTime @default(now())

  @@index([chatId, role, active])
  @@index([versionGroup])
}

model AiSettings {
  id        String   @id @default("singleton")
  settings  Json
  updatedAt DateTime @updatedAt
}

model VectorDocument {
  id        String   @id @default(cuid())
  projectId String
  source    String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
